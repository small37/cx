{
  "hooks": {
    "Notification": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.touchbar-island/bin/tbmsg 'Claude 有新通知'"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.touchbar-island/bin/tbpermission 'Claude 需要你确认权限'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.touchbar-island/bin/tbdone '任务完成'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.touchbar-island/bin/tbmsg '工具调用完成'"
          }
        ]
      }
    ],
    "Error": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.touchbar-island/bin/tberror '命令执行失败'"
          }
        ]
      }
    ]
  }
}

